# Phase 2: Full Stack Deployment - Environment Configuration

# ──────────────────────────────────────────────────────────────────────────────
# AZURE COGNITIVE SERVICES - STT & TTS
# ──────────────────────────────────────────────────────────────────────────────
# Get these from Azure Portal → Cognitive Services → Speech service

SPEECH_KEY=your-azure-speech-key
SPEECH_REGION=your-region  # e.g., eastus, westus2, etc.

# ──────────────────────────────────────────────────────────────────────────────
# GROQ API - LLM Service
# ──────────────────────────────────────────────────────────────────────────────
# Get from https://console.groq.com/keys

GROQ_API_KEY=your-groq-api-key

# ──────────────────────────────────────────────────────────────────────────────
# REDIS - Automatically configured (docker-compose internal)
# ──────────────────────────────────────────────────────────────────────────────
# These are set by docker-compose, no need to change:
# REDIS_URL=redis://redis:6379
# STT_URL=ws://stt-service:8001/stt
# LLM_URL=ws://llm-service:8002/llm
# TTS_URL=ws://tts-service:8003/tts
