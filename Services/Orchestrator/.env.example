# Orchestrator Service Configuration
# Copy this file to .env and customize for your environment

# ──────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (Phase 1)
# ──────────────────────────────────────────────────────────────────────────────

# Local Docker Redis (development)
REDIS_URL=redis://redis:6379

# DigitalOcean Managed Redis (production)
# Get connection string from DigitalOcean dashboard
# REDIS_URL=rediss://default:PASSWORD@db-hostname.ondigitalocean.com:25061

# ──────────────────────────────────────────────────────────────────────────────
# BACKEND SERVICE URLS
# ──────────────────────────────────────────────────────────────────────────────

# Docker Compose (development - mock services)
STT_URL=ws://stt-service:8001/stt
LLM_URL=ws://llm-service:8002/llm
TTS_URL=ws://tts-service:8003/tts

# Kubernetes (production naming)
# STT_URL=ws://stt-service.default:8001/stt
# LLM_URL=ws://llm-service.default:8002/llm
# TTS_URL=ws://tts-service.default:8003/tts

# Local services running outside Docker (testing)
# STT_URL=ws://host.docker.internal:8001/stt
# LLM_URL=ws://host.docker.internal:8002/llm
# TTS_URL=ws://host.docker.internal:8003/tts

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: LOGGING & DEBUG
# ──────────────────────────────────────────────────────────────────────────────

# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
